{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorktreeDesk",
  "version": "0.1.5",
  "identifier": "com.codex.worktreedesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Worktree Desk",
        "width": 1326,
        "height": 1037,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "nsis",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3MUQyN0RDNDAzMENBNjcKUldSbnlqQkEzQ2NkUjJuMWJNWnFGV0NpV2pwYlp0ako1MDNjY25BRENpNWtDbVJZOG1nT2tld3gK",
      "endpoints": [
        "https://github.com/HelloWorldImJoe/WorkTreeDesk/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
